[core]

	editor = nova -w
	excludesfile = ~/.gitignore-global

[diff]

	# Detect copies as well as renames
	renames = copies

[merge]

	# Include summaries of merged commits in newly created merge commit messages
	log = true

[user]

	name = Laurent Boileau
	email = lboileau@mirego.com

[init]

	defaultBranch = main

